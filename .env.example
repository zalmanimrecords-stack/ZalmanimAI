# Copy to .env for local development. Docker Compose loads .env from this directory.

# Postgres (used by docker-compose.yml)
POSTGRES_DB=labelops
POSTGRES_USER=label
POSTGRES_PASSWORD=label

# MinIO (optional overrides)
# MINIO_ROOT_USER=minio
# MINIO_ROOT_PASSWORD=miniopassword

# API (local dev)
ENVIRONMENT=development
API_DOCS_ENABLED=false
DATABASE_URL=postgresql+psycopg2://label:label@localhost:5432/labelops
JWT_SECRET=replace-this-with-a-long-local-dev-secret-at-least-32-chars
TOKEN_ENCRYPTION_KEY=replace-this-with-a-dedicated-token-encryption-key-at-least-32-chars
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173
TRUSTED_HOSTS=localhost,127.0.0.1,testserver

# Optional overrides
# OAUTH_ALLOWED_REDIRECT_ORIGINS=http://localhost:3000
# PUBLIC_DEMO_ALLOWED_ORIGINS=http://localhost:3000
