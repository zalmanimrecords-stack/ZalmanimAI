# Zalmanim AI MCP server configuration.
# Copy to `.env` (gitignored) and fill in real values. Shell/MCP-client env
# variables take precedence over this file.

# Backend base URL (no trailing slash). Local dev default: http://localhost:8000
ZALMANIM_API_BASE_URL=http://localhost:8000

# Admin/manager credentials the MCP uses to authenticate (POST /api/auth/login).
ZALMANIM_ADMIN_EMAIL=admin
ZALMANIM_ADMIN_PASSWORD=

# Optional: request timeout in seconds (default 30).
# ZALMANIM_API_TIMEOUT=30

# Optional: log level for the MCP process (default INFO).
# ZALMANIM_MCP_LOG_LEVEL=INFO
