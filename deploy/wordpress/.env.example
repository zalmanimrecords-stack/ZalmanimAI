# Copy to .env and set values. Used when running:
#   docker compose -f deploy/wordpress/docker-compose.yml --project-directory . --env-file deploy/wordpress/.env up -d

# Required: MySQL passwords
WORDPRESS_DB_PASSWORD=your_wp_db_password
WORDPRESS_DB_ROOT_PASSWORD=your_mysql_root_password

# Optional: defaults shown
WORDPRESS_DB_NAME=wordpress
WORDPRESS_DB_USER=wp

# WordPress site URL (for WP_HOME / WP_SITEURL). Set to your public URL when using a domain.
WORDPRESS_HOME_URL=http://localhost:8080
