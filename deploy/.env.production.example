# Copy this file to deploy/.env.production before the first production deploy.

POSTGRES_DB=labelops
POSTGRES_USER=label
POSTGRES_PASSWORD=replace-with-strong-db-password

JWT_SECRET=replace-with-a-long-random-secret
ACCESS_TOKEN_MINUTES=1440
APP_NAME=LabelOps API
API_DOCS_ENABLED=false
CORS_ALLOWED_ORIGINS=https://lm.zalmanim.com,https://artists.zalmanim.com
TRUSTED_HOSTS=lm.zalmanim.com,artists.zalmanim.com,lmapi.zalmanim.com

# Flutter web: use the same host as each SPA so requests go to /api via nginx (not cross-origin to lmapi).
API_BASE_URL=https://lm.zalmanim.com/
ARTIST_API_BASE_URL=https://artists.zalmanim.com/
OAUTH_REDIRECT_BASE=https://lmapi.zalmanim.com/api/admin/social/callback
OAUTH_SUCCESS_REDIRECT=https://lm.zalmanim.com
# Where password reset links in email point (admin client; artists can use the same link or set artist portal)
PASSWORD_RESET_BASE_URL=https://lm.zalmanim.com

# Internal Docker Postfix relay (see deploy/EMAIL_ZALMANIM_SELFHOST.md for DNS/PTR/DKIM)
SMTP_HOST=mailserver
SMTP_PORT=25
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=false
SMTP_USE_SSL=false
SMTP_FROM_EMAIL=info@zalmanim.com
MAILSERVER_ALLOWED_SENDER_DOMAINS=zalmanim.com
MAILSERVER_HOSTNAME=mail.zalmanim.com
EMAILS_PER_HOUR=30

# Incoming email ingestion (the worker polls this mailbox over IMAP, read-only, and shows
# messages in the admin Inbox tagged as "Email"). Leave IMAP_HOST empty to disable.
# Create the mailbox on docker-mailserver: `docker exec -ti mailserver setup email add simon@zalmanim.com`
IMAP_HOST=mail.familyzone.online
IMAP_PORT=993
IMAP_USE_SSL=true
IMAP_USER=simon@zalmanim.com
IMAP_PASSWORD=
IMAP_MAILBOX=INBOX
IMAP_POLL_SECONDS=120
# Unsubscribe links in campaign email (defaults from OAUTH_REDIRECT_BASE if empty)
# API_PUBLIC_BASE_URL=https://lmapi.zalmanim.com/api

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
META_CLIENT_ID=
META_CLIENT_SECRET=
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
X_CLIENT_ID=
X_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
SOUNDCLOUD_CLIENT_ID=
SOUNDCLOUD_CLIENT_SECRET=

MAILCHIMP_API_KEY=
WORDPRESS_REST_BASE_URL=
WORDPRESS_CLIENT_KEY=
WORDPRESS_CLIENT_SECRET=
DEMO_SUBMISSION_TOKEN=replace-with-a-long-random-secret
